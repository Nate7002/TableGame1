# Auto-detect text files and perform LF normalization
* text=auto

# Source and documentation — normalize to LF
*.lua   text eol=lf
*.luau  text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Roblox binary assets — do not apply line-ending normalization
*.rbxl   binary
*.rbxlx  binary
*.rbxm   binary
*.rbxmx  binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.mp3    binary
*.ogg    binary
